body {
    font-family: Arial;
    background: #f2f2f2;
    text-align: center;
}

.container {
    margin: 40px auto;
    background: white;
    padding: 20px;
    width: 80%;
    border-radius: 10px;
}

#dropArea {
    border: 2px dashed #007bff;
    padding: 30px;
    margin-bottom: 20px;
    cursor: pointer;
    background: #fafafa;
}

#dropArea:hover {
    background: #e6f0ff;
}

#fileInput {
    display: none;
}

#preview img {
    width: 120px;
    margin: 10px;
    border-radius: 10px;
}

button {
    padding: 10px 20px;
    background: green;
    color: white;
    border: none;
    cursor: pointer;
}
