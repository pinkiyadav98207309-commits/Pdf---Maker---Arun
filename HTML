<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Photo to PDF (A4 + Drag Drop)</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<div class="container">
    <h1>📄 Photo to PDF (A4)</h1>

    <div id="dropArea">
        <p>📥 Drag & Drop Images Here</p>
        <input type="file" id="fileInput" multiple accept="image/*">
    </div>

    <div id="preview"></div>

    <button onclick="createPDF()">Create A4 PDF</button>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="script.js"></script>

</body>
</html>
